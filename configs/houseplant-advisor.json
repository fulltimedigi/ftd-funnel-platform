{
  "_note": "Houseplant Advisor — built per the FullTimeDigi standard + engine reference, zero engine edits. Decision-table funnel. Pet-toxicity is the safety/disqualification gate; 'readiness' is a derived gate (care × experience, low-light clamp); 'thriving' short-circuits to advanced.",
  "id": "houseplant-advisor",
  "brand": { "name": "نَبتة", "logo": "", "tagline": "مرشد اختيار نبتتك المنزلية" },
  "theme": "platform-clean",
  "lang": "ar",
  "hero": {
    "eyebrow": "٥ أسئلة · دقيقة واحدة",
    "headline": "أي نبتة منزلية تناسبك؟",
    "headlineAccent": "",
    "subtext": "جاوب على أسئلة سريعة ونوصّلك بالنبتة الأنسب لمنزلك وحيواناتك ووقتك — مع شرح واضح لماذا هي الأنسب.",
    "chips": ["٥ أسئلة", "آمن للحيوانات", "نتيجة فورية"],
    "startLabel": "ابدأ ←"
  },

  "scoring": { "mode": "decision-table" },

  "signals": [
    { "id": "experience", "role": "decision", "required": true, "source": "q_experience",
      "domain": ["none", "struggled", "some", "thriving"],
      "map": { "opt_none": "none", "opt_struggled": "struggled", "opt_some": "some", "opt_thriving": "thriving" } },
    { "id": "care", "role": "decision", "required": true, "source": "q_care", "default": "unsure",
      "domain": ["minimal", "regular", "unsure"],
      "map": { "opt_minimal": "minimal", "opt_regular": "regular", "opt_careunsure": "unsure" } },
    { "id": "light", "role": "decision", "required": true, "source": "q_light",
      "domain": ["low", "bright"],
      "map": { "opt_low": "low", "opt_bright": "bright" } },
    { "id": "pets", "role": "decision", "required": true, "source": "q_pets",
      "domain": ["pets", "none"],
      "map": { "opt_pets": "pets", "opt_nopets": "none" } },
    { "id": "goal", "role": "presentation", "required": false, "default": "unsure", "source": "q_goal",
      "domain": ["aesthetics", "air_quality", "hobby", "gift", "unsure"],
      "map": { "opt_aesthetics": "aesthetics", "opt_air": "air_quality", "opt_hobby": "hobby", "opt_gift": "gift" } }
  ],

  "derivedSignals": [
    { "id": "DS_pets", "from": ["pets"], "rule": "identity", "domain": ["pets", "none"] },
    { "id": "DS_light", "from": ["light"], "rule": "identity", "domain": ["low", "bright"] },
    {
      "id": "DS_tier", "from": ["experience"], "rule": "cases",
      "domain": ["new", "growing", "expert"], "default": "new",
      "cases": [
        { "when": { "experience": "thriving" }, "value": "expert" },
        { "when": { "experience": "some" }, "value": "growing" }
      ]
    },
    {
      "id": "DS_ready", "from": ["care", "experience", "light"], "rule": "cases",
      "domain": ["easy", "demanding", "unsure"], "default": "easy",
      "cases": [
        { "when": { "care": "unsure" }, "value": "unsure" },
        { "when": { "care": "regular", "experience": ["some", "thriving"] }, "value": "demanding" }
      ],
      "clamp": [ { "when": { "light": "low" }, "ifValue": "demanding", "to": "easy" } ]
    }
  ],

  "decisionTable": [
    { "id": "r1_expert",          "when": { "DS_tier": "expert" },                          "result": "EXPERT" },
    { "id": "r2_pets_demanding",  "when": { "DS_pets": "pets", "DS_ready": "demanding" },    "result": "SAFE_FUSSY" },
    { "id": "r3_pets_easy",       "when": { "DS_pets": "pets", "DS_ready": ["easy", "unsure"] }, "result": "SAFE_EASY" },
    { "id": "r4_demanding",       "when": { "DS_ready": "demanding" },                       "result": "FUSSY" },
    { "id": "r5_easy_low",        "when": { "DS_ready": "easy", "DS_light": "low" },         "result": "LOWLIGHT" },
    { "id": "r6_easy_bright",     "when": { "DS_ready": "easy", "DS_light": "bright" },      "result": "BRIGHT" },
    { "id": "r7_unsure",          "when": { "DS_ready": "unsure" },                          "result": "SAFESTART" },
    { "id": "r8_safety_default",  "when": {},                                                "result": "SAFESTART" }
  ],

